<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="CakeProject.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:CakeProject"
    xmlns:views="clr-namespace:CakeProject.Views"
    Title="CakeProject">

    <ShellContent
        Title="Home"
        ContentTemplate="{DataTemplate local:MainPage}"
        Route="MainPage" />

    <ShellContent
        Title="Gudang"
        ContentTemplate="{DataTemplate views:GudangPage}"
        Route="GudangPage" />

    <ShellContent
        Title="Dapur"
        ContentTemplate="{DataTemplate views:DapurPage}"
        Route="DapurPage" />

    <ShellContent
        Title="Admin"
        ContentTemplate="{DataTemplate views:AdminPage}"
        Route="AdminPage" />

    <ShellContent
        Title="POS"
        ContentTemplate="{DataTemplate views:PosPage}"
        Route="PosPage" />

    <ShellContent
        Title="Customer"
        ContentTemplate="{DataTemplate views:CustomerPage}"
        Route="CustomerPage" />

</Shell>