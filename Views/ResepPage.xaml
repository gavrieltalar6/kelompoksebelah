<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:CakeProject.ViewModels"
             x:Class="CakeProject.Views.ResepPage"
             BackgroundColor="#F1CBF1"
             Title="Setting Resep">

    <Grid RowDefinitions="*,70">

        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="20" Spacing="20">

                <!-- HEADER -->
                <Grid ColumnDefinitions="*,Auto">
                    <Label Text="Setting Resep Kue"
                           FontSize="24"
                           FontAttributes="Bold"
                           VerticalOptions="Center"/>
                    <Button Grid.Column="1"
                            Text="+"
                            FontSize="24"
                            BackgroundColor="#D6B3D9"
                            TextColor="Black"
                            CornerRadius="20"
                            WidthRequest="50"
                            HeightRequest="50"
                            Command="{Binding TambahKueBaruCommand}"/>
                </Grid>

                <!-- PILIH KUE -->
                <Border BackgroundColor="White" StrokeShape="RoundRectangle 20" Padding="15">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Pilih Kue" FontAttributes="Bold" FontSize="16" TextColor="Black"/>
                        <CollectionView ItemsSource="{Binding DaftarKue}" HeightRequest="80">
                            <CollectionView.ItemsLayout>
                                <LinearItemsLayout Orientation="Horizontal" ItemSpacing="10"/>
                            </CollectionView.ItemsLayout>
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <VerticalStackLayout Spacing="4">
                                        <Button Text="{Binding NamaKue}"
                                                FontSize="12"
                                                CornerRadius="15"
                                                TextColor="Black"
                                                BackgroundColor="#D6B3D9"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.PilihKueCommand}"
                                                CommandParameter="{Binding .}"/>
                                        <Button Text="🗑 Hapus"
                                                FontSize="10"
                                                CornerRadius="10"
                                                BackgroundColor="#F26C6C"
                                                TextColor="White"
                                                HeightRequest="28"
                                                Padding="0"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.HapusKueCommand}"
                                                CommandParameter="{Binding .}"/>
                                    </VerticalStackLayout>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </Border>

                <!-- DETAIL RESEP -->
                <Border BackgroundColor="White"
                        StrokeShape="RoundRectangle 20"
                        Padding="15"
                        IsVisible="{Binding AdaKueTerpilih}">
                    <VerticalStackLayout Spacing="15">

                        <Label Text="{Binding KueTerpilih.NamaKue, StringFormat='Resep: {0}'}"
                               FontAttributes="Bold"
                               FontSize="18"
                               TextColor="Black"/>

                        <Label Text="Lama Masak (menit)" FontAttributes="Bold" TextColor="Black"/>
                        <Border StrokeShape="RoundRectangle 15" Padding="5">
                            <Entry Keyboard="Numeric" Text="{Binding LamaMasakText}" Placeholder="menit"/>
                        </Border>

                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="Daftar Bahan"
                                   FontAttributes="Bold"
                                   FontSize="16"
                                   TextColor="Black"
                                   VerticalOptions="Center"/>
                            <Button Grid.Column="1"
                                    Text="+ Tambah Bahan"
                                    FontSize="11"
                                    BackgroundColor="#D6B3D9"
                                    TextColor="Black"
                                    CornerRadius="10"
                                    Command="{Binding TambahBahanCommand}"/>
                        </Grid>

                        <VerticalStackLayout x:Name="BahanContainer" Spacing="8"/>

                        <Button Text="Simpan Resep"
                                BackgroundColor="#D6B3D9"
                                TextColor="Black"
                                FontAttributes="Bold"
                                CornerRadius="20"
                                Command="{Binding SimpanResepCommand}"/>

                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

        <!-- BOTTOM NAV -->
        <Border Grid.Row="1" BackgroundColor="White" Margin="5" Padding="5">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="20"/>
            </Border.StrokeShape>
            <Grid ColumnDefinitions="*,*,*,*,*,*">

                <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="2">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnAdminClicked"/>
                    </VerticalStackLayout.GestureRecognizers>
                    <Border BackgroundColor="Transparent" Padding="8,5" HorizontalOptions="Center">
                        <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                        <Label Text="🏠" FontSize="20" HorizontalOptions="Center"/>
                    </Border>
                    <Label Text="Admin" FontSize="10" TextColor="#888888" HorizontalOptions="Center"/>
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center" VerticalOptions="Center" Spacing="2">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnGudangClicked"/>
                    </VerticalStackLayout.GestureRecognizers>
                    <Border BackgroundColor="Transparent" Padding="8,5" HorizontalOptions="Center">
                        <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                        <Label Text="🏭" FontSize="20" HorizontalOptions="Center"/>
                    </Border>
                    <Label Text="Gudang" FontSize="10" TextColor="#888888" HorizontalOptions="Center"/>
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Column="2" HorizontalOptions="Center" VerticalOptions="Center" Spacing="2">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnDapurClicked"/>
                    </VerticalStackLayout.GestureRecognizers>
                    <Border BackgroundColor="Transparent" Padding="8,5" HorizontalOptions="Center">
                        <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                        <Label Text="🍳" FontSize="20" HorizontalOptions="Center"/>
                    </Border>
                    <Label Text="Dapur" FontSize="10" TextColor="#888888" HorizontalOptions="Center"/>
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Column="3" HorizontalOptions="Center" VerticalOptions="Center" Spacing="2">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnResepClicked"/>
                    </VerticalStackLayout.GestureRecognizers>
                    <Border BackgroundColor="#EBD5EB" Padding="8,5" HorizontalOptions="Center">
                        <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                        <Label Text="📖" FontSize="20" HorizontalOptions="Center"/>
                    </Border>
                     <Label Text="Resep" FontSize="10" FontAttributes="Bold" TextColor="#7B3F7B" HorizontalOptions="Center"/>
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Column="4" HorizontalOptions="Center" VerticalOptions="Center" Spacing="2">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnKasirClicked"/>
                    </VerticalStackLayout.GestureRecognizers>
                    <Border BackgroundColor="Transparent" Padding="8,5" HorizontalOptions="Center">
                        <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                        <Label Text="🧾" FontSize="20" HorizontalOptions="Center"/>
                    </Border>
                    <Label Text="POS" FontSize="10" TextColor="#888888" HorizontalOptions="Center"/>
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Column="5" HorizontalOptions="Center" VerticalOptions="Center" Spacing="2">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnMemberClicked"/>
                    </VerticalStackLayout.GestureRecognizers>
                    <Border BackgroundColor="Transparent" Padding="8,5" HorizontalOptions="Center">
                        <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                        <Label Text="👥" FontSize="20" HorizontalOptions="Center"/>
                    </Border>
                    <Label Text="Member" FontSize="10" TextColor="#888888" HorizontalOptions="Center"/>
                </VerticalStackLayout>

            </Grid>
        </Border>
    </Grid>
</ContentPage>
