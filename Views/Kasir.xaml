<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Background="#F1CBF1"
        x:Class="App1.MainWindow">
    <Window.Resources>
        <FontFamily x:Key="JaroFont">/Assets/Jaro.ttf#Jaro</FontFamily>
        <Style TargetType="TextBlock">
            <Setter Property="FontFamily"
                    Value="{StaticResource JaroFont}"/>
        </Style>
    </Window.Resources>
    <Grid Margin="20,10,20,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <!-- TOP NAVIGATION BAR -->
        <Grid Grid.Row="0"
                VerticalAlignment="Top">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <!-- Back Arrow -->
            <TextBlock Grid.Column="0"
                    Text="←"
                    FontSize="28"
                    FontWeight="Bold"
                    Foreground="Black"
                    VerticalAlignment="Center"/>
            <Image Source="https://img.icons8.com/ios-filled/48/000000/help.png"
                    Width="28"
                    Height="28"
                    Margin="0,0,0,0"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Grid.Column="2"/>
            <!-- Help Icon -->
        </Grid>
        <!-- SCROLLABLE CONTENT -->
        <ScrollViewer Grid.Row="1"
                VerticalScrollBarVisibility="Hidden">
            <StackPanel Margin="0,0,0,20">
                <!-- ========================================== -->
                <!-- CARD 1: PRODUK (Products)                  -->
                <!-- ========================================== -->
                <Border Background="White"
                        CornerRadius="20"
                        Padding="20"
                        Margin="0,0,0,20">
                    <StackPanel>
                        <!-- Search and Category Row -->
                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <!-- Search Input -->
                            <Border Grid.Column="0"
                                    BorderBrush="#D3D3D3"
                                    BorderThickness="1"
                                    CornerRadius="20"
                                    Padding="15,8"
                                    Margin="0,0,10,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🔍"
                                            FontSize="16"
                                            VerticalAlignment="Center"
                                            Foreground="Black"
                                            Margin="0,0,10,0"/>
                                    <TextBlock Text="Cari kue..."
                                            FontSize="14"
                                            VerticalAlignment="Center"
                                            Foreground="Black"/>
                                </StackPanel>
                            </Border>
                            <!-- Category Button / With Help Logo Image -->
                            <Border Grid.Column="1"
                                    Background="#E3BCE3"
                                    CornerRadius="20"
                                    Padding="15,8">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Categorier"
                                            FontSize="12"
                                            VerticalAlignment="Center"
                                            Foreground="Black"
                                            Margin="0,0,5,0"/>
                                    <TextBlock Text="▼"
                                            FontSize="10"
                                            VerticalAlignment="Center"
                                            Foreground="White"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                        <!-- Product Grid Row 1 -->
                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <!-- Product 1 -->
                            <StackPanel Grid.Column="0"
                                    HorizontalAlignment="Center"
                                    Margin="0,0,5,0">
                                <Border CornerRadius="40"
                                        Height="80"
                                        Width="80"
                                        ClipToBounds="True"
                                        HorizontalAlignment="Center"
                                        Margin="0,0,0,5"
                                        Background="LightGray">
                                    <Image Source="tiramisu.png"
                                            Stretch="UniformToFill"/>
                                </Border>
                                <TextBlock Text="Kue Tiramisu"
                                        FontSize="14"
                                        Foreground="Black"
                                        TextAlignment="Center"/>
                                <TextBlock Text="Rp 20k"
                                        FontSize="14"
                                        Foreground="Black"
                                        TextAlignment="Center"/>
                            </StackPanel>
                            <!-- Product 2 -->
                            <StackPanel Grid.Column="1"
                                    HorizontalAlignment="Center"
                                    Margin="5,0,5,0">
                                <Border CornerRadius="20"
                                        Height="80"
                                        Width="80"
                                        ClipToBounds="True"
                                        HorizontalAlignment="Center"
                                        Margin="0,0,0,5"
                                        Background="LightGray">
                                    <Image Source="balok.png"
                                            Stretch="UniformToFill"/>
                                </Border>
                                <TextBlock Text="Kue Balok Cokelat"
                                        FontSize="14"
                                        Foreground="Black"
                                        TextAlignment="Center"/>
                                <TextBlock Text="Rp 50k"
                                        FontSize="14"
                                        Foreground="Black"
                                        TextAlignment="Center"/>
                            </StackPanel>
                            <!-- Product 3 -->
                            <StackPanel Grid.Column="2"
                                    HorizontalAlignment="Center"
                                    Margin="5,0,0,0">
                                <Border CornerRadius="30"
                                        Height="80"
                                        Width="80"
                                        ClipToBounds="True"
                                        HorizontalAlignment="Center"
                                        Margin="0,0,0,5"
                                        Background="LightGray">
                                    <Image Source="vanila.png"
                                            Stretch="UniformToFill"/>
                                </Border>
                                <TextBlock Text="Kue Ultah Vanila"
                                        FontSize="14"
                                        Foreground="Black"
                                        TextAlignment="Center"/>
                                <TextBlock Text="Rp 100k"
                                        FontSize="14"
                                        Foreground="Black"
                                        TextAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                        <!-- Product Grid Row 2 -->
                        <Grid HorizontalAlignment="Center"
                                Width="250">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <!-- Product 4 -->
                            <StackPanel Grid.Column="0"
                                    HorizontalAlignment="Center"
                                    Margin="0,0,5,0">
                                <Border CornerRadius="40"
                                        Height="80"
                                        Width="80"
                                        ClipToBounds="True"
                                        HorizontalAlignment="Center"
                                        Margin="0,0,0,5"
                                        Background="LightGray">
                                    <Image Source="pig.png"
                                            Stretch="UniformToFill"/>
                                </Border>
                                <TextBlock Text="Kue Brownies Babi"
                                        FontSize="14"
                                        Foreground="Black"
                                        TextAlignment="Center"/>
                                <TextBlock Text="Rp 150k"
                                        FontSize="14"
                                        Foreground="Black"
                                        TextAlignment="Center"/>
                            </StackPanel>
                            <!-- Product 5 -->
                            <StackPanel Grid.Column="1"
                                    HorizontalAlignment="Center"
                                    Margin="5,0,0,0">
                                <Border CornerRadius="40"
                                        Height="80"
                                        Width="80"
                                        ClipToBounds="True"
                                        HorizontalAlignment="Center"
                                        Margin="0,0,0,5"
                                        Background="LightGray">
                                    <Image Source="roblox.png"
                                            Stretch="UniformToFill"/>
                                </Border>
                                <TextBlock Text="Kue Roblox"
                                        FontSize="14"
                                        Foreground="Black"
                                        TextAlignment="Center"/>
                                <TextBlock Text="Rp 170k"
                                        FontSize="14"
                                        Foreground="Black"
                                        TextAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>
                <!-- ========================================== -->
                <!-- CARD 2: KERANJANG BELANJA (Cart)           -->
                <!-- ========================================== -->
                <Border Background="White"
                        CornerRadius="20"
                        Padding="20">
                    <StackPanel>
                        <!-- Cart Header -->
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Keranjang belanja"
                                    FontSize="26"
                                    Foreground="Black"/>
                            <TextBlock Grid.Column="1"
                                    Text="🗑"
                                    FontSize="20"
                                    Foreground="Black"
                                    VerticalAlignment="Center"/>
                        </Grid>
                        <!-- Table Headers -->
                        <Grid Margin="0,5,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="1.5*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                    Text="Product"
                                    FontSize="14"
                                    Foreground="Black"
                                    FontWeight="Bold"/>
                            <TextBlock Grid.Column="1"
                                    Text="Quantity"
                                    FontSize="14"
                                    Foreground="Black"
                                    TextAlignment="Center"
                                    FontWeight="Bold"/>
                            <TextBlock Grid.Column="2"
                                    Text="Subtotal"
                                    FontSize="14"
                                    Foreground="Black"
                                    TextAlignment="Right"
                                    FontWeight="Bold"/>
                        </Grid>
                        <Rectangle Fill="Black"
                                Height="1"
                                Margin="0,5,0,10"/>
                        <!-- Cart Item 1 -->
                        <Grid Margin="0,5,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <!-- Image -->
                            <Border Grid.Column="0"
                                    CornerRadius="30"
                                    Height="60"
                                    Width="60"
                                    ClipToBounds="True"
                                    Margin="0,0,15,0"
                                    Background="LightGray">
                                <Image Source="tiramisu.png"
                                        Stretch="UniformToFill"/>
                            </Border>
                            <!-- Info -->
                            <StackPanel Grid.Column="1"
                                    VerticalAlignment="Center"
                                    Margin="0,0,15,0">
                                <TextBlock Text="Kue Tiramisu"
                                        FontSize="14"
                                        Foreground="Black"
                                        FontWeight="Bold"/>
                                <TextBlock Text="Rp 20k"
                                        FontSize="14"
                                        Foreground="Black"
                                        FontWeight="Bold"/>
                            </StackPanel>
                            <!-- Quantity -->
                            <StackPanel Grid.Column="2"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    Margin="0,0,15,0">
                                <TextBlock Text="—"
                                        FontWeight="Bold"
                                        Foreground="Black"
                                        VerticalAlignment="Center"
                                        Margin="0,0,10,0"/>
                                <Border Background="#E3BCE3"
                                        CornerRadius="15"
                                        Height="30"
                                        Width="30">
                                    <TextBlock Text="1"
                                            FontSize="16"
                                            Foreground="Black"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            FontWeight="Bold"/>
                                </Border>
                                <TextBlock Text="+"
                                        FontWeight="Bold"
                                        FontSize="18"
                                        Foreground="Black"
                                        VerticalAlignment="Center"
                                        Margin="10,0,0,0"/>
                            </StackPanel>
                            <!-- Subtotal -->
                            <TextBlock Grid.Column="3"
                                    Text="Rp 550.000"
                                    FontSize="16"
                                    Foreground="Black"
                                    VerticalAlignment="Center"
                                    FontWeight="Bold"/>
                        </Grid>
                        <!-- Cart Item 2 -->
                        <Grid Margin="0,5,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0"
                                    CornerRadius="10"
                                    Height="60"
                                    Width="60"
                                    ClipToBounds="True"
                                    Margin="0,0,15,0"
                                    Background="LightGray">
                                <Image Source="balok.png"
                                        Stretch="UniformToFill"/>
                            </Border>
                            <StackPanel Grid.Column="1"
                                    VerticalAlignment="Center"
                                    Margin="0,0,15,0">
                                <TextBlock Text="Kue Balok Cokelat"
                                        FontSize="14"
                                        Foreground="Black"
                                        FontWeight="Bold"/>
                                <TextBlock Text="Rp 50k"
                                        FontSize="14"
                                        Foreground="Black"
                                        FontWeight="Bold"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    Margin="0,0,15,0">
                                <TextBlock Text="—"
                                        FontWeight="Bold"
                                        Foreground="Black"
                                        VerticalAlignment="Center"
                                        Margin="0,0,10,0"/>
                                <Border Background="#E3BCE3"
                                        CornerRadius="15"
                                        Height="30"
                                        Width="30">
                                    <TextBlock Text="1"
                                            FontSize="16"
                                            Foreground="Black"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            FontWeight="Bold"/>
                                </Border>
                                <TextBlock Text="+"
                                        FontWeight="Bold"
                                        FontSize="18"
                                        Foreground="Black"
                                        VerticalAlignment="Center"
                                        Margin="10,0,0,0"/>
                            </StackPanel>
                            <TextBlock Grid.Column="3"
                                    Text="Rp 550.000"
                                    FontSize="16"
                                    Foreground="Black"
                                    VerticalAlignment="Center"
                                    FontWeight="Bold"/>
                        </Grid>
                        <!-- Cart Item 3 -->
                        <Grid Margin="0,5,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0"
                                    CornerRadius="30"
                                    Height="60"
                                    Width="60"
                                    ClipToBounds="True"
                                    Margin="0,0,15,0"
                                    Background="LightGray">
                                <Image Source="roblox.png"
                                        Stretch="UniformToFill"/>
                            </Border>
                            <StackPanel Grid.Column="1"
                                    VerticalAlignment="Center"
                                    Margin="0,0,15,0">
                                <TextBlock Text="Kue Roblox"
                                        FontSize="14"
                                        Foreground="Black"
                                        FontWeight="Bold"/>
                                <TextBlock Text="Rp 170k"
                                        FontSize="14"
                                        Foreground="Black"
                                        FontWeight="Bold"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    Margin="0,0,15,0">
                                <TextBlock Text="—"
                                        FontWeight="Bold"
                                        Foreground="Black"
                                        VerticalAlignment="Center"
                                        Margin="0,0,10,0"/>
                                <Border Background="#E3BCE3"
                                        CornerRadius="15"
                                        Height="30"
                                        Width="30">
                                    <TextBlock Text="1"
                                            FontSize="16"
                                            Foreground="Black"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            FontWeight="Bold"/>
                                </Border>
                                <TextBlock Text="+"
                                        FontWeight="Bold"
                                        FontSize="18"
                                        Foreground="Black"
                                        VerticalAlignment="Center"
                                        Margin="10,0,0,0"/>
                            </StackPanel>
                            <TextBlock Grid.Column="3"
                                    Text="Rp 550.000"
                                    FontSize="16"
                                    Foreground="Black"
                                    VerticalAlignment="Center"
                                    FontWeight="Bold"/>
                        </Grid>
                        <!-- Footer Total -->
                        <Rectangle Fill="Black"
                                Height="1"
                                Margin="0,10,0,10"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                    Text="Subtotal"
                                    FontSize="26"
                                    Foreground="Black"
                                    FontWeight="Bold"/>
                            <TextBlock Grid.Column="1"
                                    Text="Rp 550.000"
                                    FontSize="22"
                                    Foreground="Black"
                                    VerticalAlignment="Center"
                                    FontWeight="Bold"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>