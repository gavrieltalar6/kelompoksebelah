<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:CakeProject.ViewModels"
             x:Class="CakeProject.Views.PosPage"
             BackgroundColor="#F1CBF1">

    <ScrollView>
        <VerticalStackLayout Padding="20"
                Spacing="20">

            <!-- HEADER -->
            <Grid ColumnDefinitions="Auto,*,Auto">
                <Label Text="←"
                        FontSize="28"
                        FontAttributes="Bold"
                        VerticalOptions="Center"/>
                <Label Grid.Column="2"
                        Text="?"
                        FontSize="20"
                        VerticalOptions="Center"/>
            </Grid>

            <!-- CARD 1: PRODUK -->
            <Frame BackgroundColor="White"
                    CornerRadius="20"
                    Padding="20">
                <VerticalStackLayout Spacing="15">

                    <!-- Search & Kategori -->
                    <Grid ColumnDefinitions="*,Auto">
                        <Frame Grid.Column="0"
                               CornerRadius="20"
                               Padding="10,8"
                               BorderColor="#D3D3D3"
                               Margin="0,0,10,0">
                            <Grid ColumnDefinitions="Auto,*">
                                <Label Text="🔍"
                                        VerticalOptions="Center"
                                        Margin="0,0,8,0"/>
                                <Entry Grid.Column="1"
                                       Placeholder="Cari kue..."
                                       Text="{Binding KataCari}"/>
                            </Grid>
                        </Frame>

                        <Frame Grid.Column="1"
                               BackgroundColor="#E3BCE3"
                               CornerRadius="20"
                               Padding="15,8"
                               BorderColor="Transparent">
                            <Label Text="Kategori ▼"
                                    FontSize="12"
                                    VerticalOptions="Center"/>
                        </Frame>
                    </Grid>

                    <!-- Grid Produk -->
                    <CollectionView ItemsSource="{Binding DaftarProduk}"
                                    SelectionMode="None">
                        <CollectionView.ItemsLayout>
                            <GridItemsLayout Orientation="Vertical"
                                             Span="3"
                                             HorizontalItemSpacing="8"
                                             VerticalItemSpacing="8"/>
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <VerticalStackLayout HorizontalOptions="Center"
                                                     Spacing="4">
                                    <Frame CornerRadius="40"
                                           HeightRequest="80"
                                           WidthRequest="80"
                                           BackgroundColor="LightGray"
                                           Padding="0"
                                           BorderColor="Transparent"
                                           HorizontalOptions="Center">
                                        <Label Text="🎂"
                                               FontSize="36"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center"/>
                                    </Frame>
                                    <Label Text="{Binding NamaBarang}"
                                           FontSize="12"
                                           HorizontalOptions="Center"
                                           HorizontalTextAlignment="Center"/>
                                    <Label Text="{Binding HargaJual, StringFormat='Rp {0:N0}'}"
                                           FontSize="12"
                                           HorizontalOptions="Center"/>

                                    <!-- TAMBAH INI -->
                                    <Label Text="{Binding JumlahStok, StringFormat='Stok: {0}'}"
                                           FontSize="10"
                                           HorizontalOptions="Center"
                                           TextColor="{Binding JumlahStok, Converter={StaticResource StokColorConverter}}"/>

                                    <Button Text="+ Tambah"
                                            FontSize="10"
                                            BackgroundColor="#D6B3D9"
                                            CornerRadius="10"
                                            Padding="8,4"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.TambahKeKeranjangCommand}"
                                            CommandParameter="{Binding .}"/>
                                </VerticalStackLayout>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                </VerticalStackLayout>
            </Frame>

            <!-- CARD 2: KERANJANG -->
            <Frame BackgroundColor="White"
                    CornerRadius="20"
                    Padding="20">
                <VerticalStackLayout Spacing="10">

                    <!-- Header Keranjang -->
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Text="Keranjang belanja"
                               FontSize="22"
                               FontAttributes="Bold"/>
                        <Button Grid.Column="1"
                                Text="🗑"
                                FontSize="20"
                                BackgroundColor="Transparent"
                                Command="{Binding HapusKeranjangCommand}"/>
                    </Grid>

                    <!-- Table Header -->
                    <Grid ColumnDefinitions="2*,1*,1.5*">
                        <Label Text="Produk"
                                FontAttributes="Bold"/>
                        <Label Grid.Column="1"
                                Text="Qty"
                                FontAttributes="Bold"
                                HorizontalOptions="Center"/>
                        <Label Grid.Column="2"
                                Text="Subtotal"
                                FontAttributes="Bold"
                                HorizontalOptions="End"/>
                    </Grid>

                    <BoxView HeightRequest="1"
                            BackgroundColor="Black"/>

                    <!-- Item Keranjang -->
                    <CollectionView ItemsSource="{Binding Keranjang}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="Auto,*,Auto,Auto"
                                      Padding="0,8">

                                    <!-- Gambar placeholder -->
                                    <Frame Grid.Column="0"
                                           CornerRadius="30"
                                           HeightRequest="60"
                                           WidthRequest="60"
                                           BackgroundColor="LightGray"
                                           Padding="0"
                                           BorderColor="Transparent"
                                           Margin="0,0,10,0">
                                        <Label Text="🎂"
                                               FontSize="28"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center"/>
                                    </Frame>

                                    <!-- Info -->
                                    <VerticalStackLayout Grid.Column="1"
                                                         VerticalOptions="Center"
                                                         Margin="0,0,10,0">
                                        <Label Text="{Binding Produk.NamaBarang}"
                                               FontAttributes="Bold"
                                               FontSize="13"/>
                                        <Label Text="{Binding Produk.HargaJual, StringFormat='Rp {0:N0}'}"
                                               FontSize="13"/>
                                    </VerticalStackLayout>

                                    <!-- Qty Controls -->
                                    <Grid Grid.Column="2"
                                          ColumnDefinitions="Auto,Auto,Auto"
                                          VerticalOptions="Center"
                                          Margin="0,0,10,0">
                                        <Button Text="—"
                                                FontAttributes="Bold"
                                                BackgroundColor="Transparent"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.KurangiJumlahCommand}"
                                                CommandParameter="{Binding .}"/>
                                        <Frame Grid.Column="1"
                                               BackgroundColor="#E3BCE3"
                                               CornerRadius="15"
                                               HeightRequest="30"
                                               WidthRequest="30"
                                               Padding="0"
                                               BorderColor="Transparent">
                                            <Label Text="{Binding Jumlah}"
                                                   FontSize="16"
                                                   FontAttributes="Bold"
                                                   HorizontalOptions="Center"
                                                   VerticalOptions="Center"/>
                                        </Frame>
                                        <Button Grid.Column="2"
                                                Text="+"
                                                FontSize="18"
                                                FontAttributes="Bold"
                                                BackgroundColor="Transparent"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.TambahJumlahCommand}"
                                                CommandParameter="{Binding .}"/>
                                    </Grid>

                                    <!-- Subtotal -->
                                    <Label Grid.Column="3"
                                           Text="{Binding SubtotalText}"
                                           FontAttributes="Bold"
                                           VerticalOptions="Center"/>
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <BoxView HeightRequest="1"
                            BackgroundColor="Black"
                            Margin="0,10"/>

                    <!-- Total -->
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Text="Total"
                               FontSize="22"
                               FontAttributes="Bold"/>
                        <Label Grid.Column="1"
                               Text="{Binding TotalHargaText}"
                               FontSize="20"
                               FontAttributes="Bold"
                               VerticalOptions="Center"/>
                    </Grid>

                    <!-- ===== SECTION MEMBER ===== -->
                    <BoxView HeightRequest="1"
                            BackgroundColor="#E0E0E0"
                            Margin="0,5"/>

                    <Label Text="Member (Opsional)"
                           FontAttributes="Bold"
                           FontSize="15"
                           TextColor="#888"/>

                    <!-- Input NoHP Customer + Tombol Cek -->
                    <VerticalStackLayout Spacing="5">
                        <Label Text="No. HP Customer"
                               FontAttributes="Bold"
                               FontSize="14"/>
                        <Grid ColumnDefinitions="*,Auto"
                                ColumnSpacing="8">
                            <Frame Grid.Column="0"
                                   CornerRadius="15"
                                   Padding="12,8"
                                   BorderColor="#D3D3D3"
                                   BackgroundColor="White">
                                <Grid ColumnDefinitions="Auto,*">
                                    <Label Text="📱"
                                            VerticalOptions="Center"
                                            Margin="0,0,8,0"/>
                                    <Entry Grid.Column="1"
                                           Placeholder="Contoh: 081234567890"
                                           Keyboard="Telephone"
                                           Text="{Binding NoHpCustomer}"/>
                                </Grid>
                            </Frame>

                            <!-- TOMBOL CEK MEMBER (baru!) -->
                            <Button Grid.Column="1"
                                    Text="Cek"
                                    BackgroundColor="#A855A8"
                                    TextColor="White"
                                    CornerRadius="15"
                                    FontAttributes="Bold"
                                    FontSize="13"
                                    Padding="15,8"
                                    Command="{Binding CariCustomerCommand}"/>
                        </Grid>

                        <!-- Info customer yang ditemukan -->
                        <Label Text="{Binding InfoCustomer}"
                               FontSize="12"
                               TextColor="#555"/>
                    </VerticalStackLayout>

                    <!-- Input Poin Ditukar -->
                    <VerticalStackLayout Spacing="5">
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="Tukar Poin"
                                   FontAttributes="Bold"
                                   FontSize="14"/>
                            <!-- InfoPoinCustomer: tampil jumlah poin milik customer -->
                            <Label Grid.Column="1"
                                   Text="{Binding InfoPoinCustomer}"
                                   FontSize="12"
                                   TextColor="#888"
                                   VerticalOptions="Center"/>
                        </Grid>
                        <Frame CornerRadius="15"
                               Padding="12,8"
                               BorderColor="#D3D3D3"
                               BackgroundColor="White">
                            <Grid ColumnDefinitions="Auto,*">
                                <Label Text="🎁"
                                        VerticalOptions="Center"
                                        Margin="0,0,8,0"/>
                                <!-- Binding ke PoinDitukarText (string) bukan PoinDitukar (int) -->
                                <Entry Grid.Column="1"
                                       Placeholder="Masukkan jumlah poin (0 = tidak pakai)"
                                       Keyboard="Numeric"
                                       Text="{Binding PoinDitukarText}"/>
                            </Grid>
                        </Frame>
                        <!-- InfoDiskonPoin: tampil nilai diskon dalam rupiah -->
                        <Label Text="{Binding InfoDiskonPoin}"
                               FontSize="12"
                               TextColor="#A855A8"
                               IsVisible="{Binding AdaDiskonPoin}"/>
                    </VerticalStackLayout>

                    <!-- Total Setelah Diskon -->
                    <Grid ColumnDefinitions="*,Auto"
                          IsVisible="{Binding AdaDiskonPoin}">
                        <Label Text="Total Setelah Diskon"
                               FontSize="16"
                               FontAttributes="Bold"
                               TextColor="#A855A8"/>
                        <Label Grid.Column="1"
                               Text="{Binding TotalSetelahDiskonText}"
                               FontSize="16"
                               FontAttributes="Bold"
                               TextColor="#A855A8"
                               VerticalOptions="Center"/>
                    </Grid>

                    <!-- Tombol Bayar -->
                    <Button Text="Bayar"
                            BackgroundColor="#D6B3D9"
                            TextColor="Black"
                            CornerRadius="20"
                            FontAttributes="Bold"
                            FontSize="16"
                            Margin="0,10,0,0"
                            Command="{Binding BayarCommand}"/>

                </VerticalStackLayout>
            </Frame>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
