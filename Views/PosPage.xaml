<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:CakeProject.ViewModels"
             x:Class="CakeProject.Views.PosPage"
             BackgroundColor="#F1CBF1">

    <Grid RowDefinitions="*,70">

        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="20" Spacing="20">

                <!-- HEADER -->
                <Grid ColumnDefinitions="Auto,*,Auto">
                    <Label Text="←" FontSize="28" FontAttributes="Bold" VerticalOptions="Center"/>
                    <Label Grid.Column="2" Text="?" FontSize="20" VerticalOptions="Center"/>
                </Grid>

                <!-- CARD 1: PRODUK -->
                <Frame BackgroundColor="White" CornerRadius="20" Padding="20">
                    <VerticalStackLayout Spacing="15">

                        <Frame CornerRadius="20" Padding="10,8" BorderColor="#D3D3D3">
                            <Grid ColumnDefinitions="Auto,*">
                                <Label Text="🔍" VerticalOptions="Center" Margin="0,0,8,0"/>
                                <Entry Grid.Column="1" Placeholder="Cari kue..." Text="{Binding KataCari}"/>
                            </Grid>
                        </Frame>

                        <CollectionView ItemsSource="{Binding DaftarProduk}" SelectionMode="None">
                            <CollectionView.ItemsLayout>
                                <GridItemsLayout Orientation="Vertical" Span="3"
                                                 HorizontalItemSpacing="8" VerticalItemSpacing="8"/>
                            </CollectionView.ItemsLayout>
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <VerticalStackLayout HorizontalOptions="Center" Spacing="4">
                                        <Frame CornerRadius="40" HeightRequest="80" WidthRequest="80"
                                               BackgroundColor="LightGray" Padding="0"
                                               BorderColor="Transparent" HorizontalOptions="Center">
                                            <Label Text="🎂" FontSize="36"
                                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                                        </Frame>
                                        <Label Text="{Binding NamaBarang}" FontSize="12"
                                               HorizontalOptions="Center" HorizontalTextAlignment="Center"/>
                                        <Label Text="{Binding HargaJual, StringFormat='Rp {0:N0}'}"
                                               FontSize="12" HorizontalOptions="Center"/>
                                        <Label Text="{Binding JumlahStok, StringFormat='Stok: {0}'}"
                                               FontSize="10" HorizontalOptions="Center"
                                               TextColor="{Binding JumlahStok, Converter={StaticResource StokColorConverter}}"/>
                                        <Button Text="+ Tambah"
                                                FontSize="10"
                                                BackgroundColor="#D6B3D9"
                                                CornerRadius="10"
                                                Padding="8,4"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.TambahKeKeranjangCommand}"
                                                CommandParameter="{Binding .}"/>
                                    </VerticalStackLayout>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>

                    </VerticalStackLayout>
                </Frame>

                <!-- CARD 2: KERANJANG -->
                <Frame BackgroundColor="White" CornerRadius="20" Padding="20">
                    <VerticalStackLayout Spacing="10">

                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="Keranjang belanja" FontSize="22" FontAttributes="Bold"/>
                            <Button Grid.Column="1" Text="🗑" FontSize="20"
                                    BackgroundColor="Transparent" Command="{Binding HapusKeranjangCommand}"/>
                        </Grid>

                        <Grid ColumnDefinitions="2*,1*,1.5*">
                            <Label Text="Produk" FontAttributes="Bold"/>
                            <Label Grid.Column="1" Text="Qty" FontAttributes="Bold" HorizontalOptions="Center"/>
                            <Label Grid.Column="2" Text="Subtotal" FontAttributes="Bold" HorizontalOptions="End"/>
                        </Grid>

                        <BoxView HeightRequest="1" BackgroundColor="Black"/>

                        <CollectionView ItemsSource="{Binding Keranjang}">
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnDefinitions="Auto,*,Auto,Auto" Padding="0,8">
                                        <Frame Grid.Column="0" CornerRadius="30" HeightRequest="60" WidthRequest="60"
                                               BackgroundColor="LightGray" Padding="0"
                                               BorderColor="Transparent" Margin="0,0,10,0">
                                            <Label Text="🎂" FontSize="28"
                                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                                        </Frame>
                                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                                            <Label Text="{Binding NamaBarang}" FontAttributes="Bold" FontSize="14"/>
                                            <Label Text="{Binding HargaJual, StringFormat='Rp {0:N0}'}"
                                                   FontSize="12" TextColor="Gray"/>
                                        </VerticalStackLayout>
                                        <Grid Grid.Column="2" ColumnDefinitions="Auto,Auto,Auto" VerticalOptions="Center">
                                            <Button Grid.Column="0" Text="-" FontSize="18" FontAttributes="Bold"
                                                    BackgroundColor="Transparent"
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.KurangiJumlahCommand}"
                                                    CommandParameter="{Binding .}"/>
                                            <Frame Grid.Column="1" CornerRadius="8" HeightRequest="32" WidthRequest="32"
                                                   BackgroundColor="#F0F0F0" Padding="0" BorderColor="Transparent">
                                                <Label Text="{Binding Jumlah}" FontAttributes="Bold"
                                                       HorizontalOptions="Center" VerticalOptions="Center"/>
                                            </Frame>
                                            <Button Grid.Column="2" Text="+" FontSize="18" FontAttributes="Bold"
                                                    BackgroundColor="Transparent"
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.TambahJumlahCommand}"
                                                    CommandParameter="{Binding .}"/>
                                        </Grid>
                                        <Label Grid.Column="3" Text="{Binding SubtotalText}"
                                               FontAttributes="Bold" VerticalOptions="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>

                        <BoxView HeightRequest="1" BackgroundColor="Black" Margin="0,10"/>

                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="Total" FontSize="22" FontAttributes="Bold"/>
                            <Label Grid.Column="1" Text="{Binding TotalHargaText}"
                                   FontSize="20" FontAttributes="Bold" VerticalOptions="Center"/>
                        </Grid>

                        <BoxView HeightRequest="1" BackgroundColor="#E0E0E0" Margin="0,5"/>

                        <Label Text="Member (Opsional)" FontAttributes="Bold" FontSize="15" TextColor="#888"/>

                        <VerticalStackLayout Spacing="5">
                            <Label Text="No. HP Customer" FontAttributes="Bold" FontSize="14"/>
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                <Frame Grid.Column="0" CornerRadius="15" Padding="12,8"
                                       BorderColor="#D3D3D3" BackgroundColor="White">
                                    <Grid ColumnDefinitions="Auto,*">
                                        <Label Text="📱" VerticalOptions="Center" Margin="0,0,8,0"/>
                                        <Entry Grid.Column="1" Placeholder="Contoh: 081234567890"
                                               Keyboard="Telephone" Text="{Binding NoHpCustomer}"/>
                                    </Grid>
                                </Frame>
                                <Button Grid.Column="1" Text="Cek"
                                        BackgroundColor="#A855A8" TextColor="White"
                                        CornerRadius="15" FontAttributes="Bold" FontSize="13"
                                        Padding="15,8" Command="{Binding CariCustomerCommand}"/>
                            </Grid>
                            <Label Text="{Binding InfoCustomer}" FontSize="12" TextColor="#555"/>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="5">
                            <Grid ColumnDefinitions="*,Auto">
                                <Label Text="Tukar Poin" FontAttributes="Bold" FontSize="14"/>
                                <Label Grid.Column="1" Text="{Binding InfoPoinCustomer}"
                                       FontSize="12" TextColor="#888" VerticalOptions="Center"/>
                            </Grid>
                            <Frame CornerRadius="15" Padding="12,8" BorderColor="#D3D3D3" BackgroundColor="White">
                                <Grid ColumnDefinitions="Auto,*">
                                    <Label Text="🎁" VerticalOptions="Center" Margin="0,0,8,0"/>
                                    <Entry Grid.Column="1"
                                           Placeholder="Masukkan jumlah poin (0 = tidak pakai)"
                                           Keyboard="Numeric"
                                           Text="{Binding PoinDitukarText}"/>
                                </Grid>
                            </Frame>
                            <Label Text="{Binding InfoDiskonPoin}" FontSize="12" TextColor="#A855A8"
                                   IsVisible="{Binding AdaDiskonPoin}"/>
                        </VerticalStackLayout>

                        <Grid ColumnDefinitions="*,Auto" IsVisible="{Binding AdaDiskonPoin}">
                            <Label Text="Total Setelah Diskon" FontSize="16" FontAttributes="Bold" TextColor="#A855A8"/>
                            <Label Grid.Column="1" Text="{Binding TotalSetelahDiskonText}"
                                   FontSize="16" FontAttributes="Bold" TextColor="#A855A8" VerticalOptions="Center"/>
                        </Grid>

                        <Button Text="Bayar"
                                BackgroundColor="#D6B3D9"
                                TextColor="Black"
                                CornerRadius="20"
                                FontAttributes="Bold"
                                FontSize="16"
                                Margin="0,10,0,0"
                                Command="{Binding BayarCommand}"/>

                    </VerticalStackLayout>
                </Frame>

            </VerticalStackLayout>
        </ScrollView>

        <!-- BOTTOM NAV -->
        <Border Grid.Row="1" BackgroundColor="White" Margin="5" Padding="5">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="20"/>
            </Border.StrokeShape>
            <Grid ColumnDefinitions="*,*,*,*,*,*">

                <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="2">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnAdminClicked"/>
                    </VerticalStackLayout.GestureRecognizers>
                    <Border BackgroundColor="Transparent" Padding="8,5" HorizontalOptions="Center">
                        <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                        <Label Text="🏠" FontSize="20" HorizontalOptions="Center"/>
                    </Border>
                    <Label Text="Admin" FontSize="10" TextColor="#888888" HorizontalOptions="Center"/>
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center" VerticalOptions="Center" Spacing="2">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnGudangClicked"/>
                    </VerticalStackLayout.GestureRecognizers>
                    <Border BackgroundColor="Transparent" Padding="8,5" HorizontalOptions="Center">
                        <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                        <Label Text="🏭" FontSize="20" HorizontalOptions="Center"/>
                    </Border>
                    <Label Text="Gudang" FontSize="10" TextColor="#888888" HorizontalOptions="Center"/>
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Column="2" HorizontalOptions="Center" VerticalOptions="Center" Spacing="2">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnDapurClicked"/>
                    </VerticalStackLayout.GestureRecognizers>
                    <Border BackgroundColor="Transparent" Padding="8,5" HorizontalOptions="Center">
                        <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                        <Label Text="🍳" FontSize="20" HorizontalOptions="Center"/>
                    </Border>
                    <Label Text="Dapur" FontSize="10" TextColor="#888888" HorizontalOptions="Center"/>
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Column="3" HorizontalOptions="Center" VerticalOptions="Center" Spacing="2">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnResepClicked"/>
                    </VerticalStackLayout.GestureRecognizers>
                    <Border BackgroundColor="Transparent" Padding="8,5" HorizontalOptions="Center">
                        <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                        <Label Text="📖" FontSize="20" HorizontalOptions="Center"/>
                    </Border>
                    <Label Text="Resep" FontSize="10" TextColor="#888888" HorizontalOptions="Center"/>
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Column="4" HorizontalOptions="Center" VerticalOptions="Center" Spacing="2">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnKasirClicked"/>
                    </VerticalStackLayout.GestureRecognizers>
                    <Border BackgroundColor="#EBD5EB" Padding="8,5" HorizontalOptions="Center">
                        <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                        <Label Text="🧾" FontSize="20" HorizontalOptions="Center"/>
                    </Border>
                    <Label Text="POS" FontSize="10" FontAttributes="Bold" TextColor="#7B3F7B" HorizontalOptions="Center"/>
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Column="5" HorizontalOptions="Center" VerticalOptions="Center" Spacing="2">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnMemberClicked"/>
                    </VerticalStackLayout.GestureRecognizers>
                    <Border BackgroundColor="Transparent" Padding="8,5" HorizontalOptions="Center">
                        <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                        <Label Text="👥" FontSize="20" HorizontalOptions="Center"/>
                    </Border>
                    <Label Text="Member" FontSize="10" TextColor="#888888" HorizontalOptions="Center"/>
                </VerticalStackLayout>

            </Grid>
        </Border>

    </Grid>
</ContentPage>
