<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="YourApp.InputInventoryPage"
             BackgroundColor="#D6B3D9">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">

            <Grid ColumnDefinitions="Auto,*,Auto">
                <Label Text="←" FontSize="20" VerticalOptions="Center"/>
                <Label Grid.Column="1"
                       Text="Input Inventory"
                       FontSize="28"
                       FontAttributes="Bold"
                       HorizontalOptions="Center"/>
                <Label Grid.Column="2"
                       Text="?" FontSize="20"
                       VerticalOptions="Center"/>
            </Grid>

            <Frame BackgroundColor="#F2F2F2"
                   CornerRadius="25"
                   Padding="20">

                <VerticalStackLayout Spacing="15">

                    <Label Text="Nama Bahan Baku" FontAttributes="Bold"/>
                    <Frame CornerRadius="15" Padding="0" BorderColor="#D6B3D9">
                        <Picker Title="Pilih bahan"/>
                    </Frame>

                    <Label Text="Kategori" FontAttributes="Bold"/>
                    <Frame CornerRadius="15" Padding="0" BorderColor="#D6B3D9">
                        <Picker Title="Pilih kategori"/>
                    </Frame>

                    <Label Text="Jumlah Bahan Masuk" FontAttributes="Bold"/>
                    <Frame CornerRadius="15" Padding="0" BorderColor="#D6B3D9">
                        <Entry Placeholder="Masukkan jumlah" Keyboard="Numeric"/>
                    </Frame>

                    <Label Text="Satuan" FontAttributes="Bold"/>

                    <Grid ColumnDefinitions="*,*,*"
                          BackgroundColor="#E3C6E8"
                          Padding="5">

                        <Button Text="Kg"
                                BackgroundColor="#BFBFBF"
                                CornerRadius="15"/>
                        <Button Text="Butir"
                                Grid.Column="1"
                                BackgroundColor="Transparent"/>
                        <Button Text="Liter"
                                Grid.Column="2"
                                BackgroundColor="Transparent"/>
                    </Grid>

                    <Label Text="Tanggal Masuk" FontAttributes="Bold"/>
                    <Frame CornerRadius="15" Padding="5" BorderColor="#D6B3D9">
                        <DatePicker/>
                    </Frame>

                    <Label Text="Tanggal Keluar" FontAttributes="Bold"/>
                    <Frame CornerRadius="15" Padding="5" BorderColor="#D6B3D9">
                        <DatePicker/>
                    </Frame>

                    <Button Text="Simpan Stock"
                            BackgroundColor="#D6B3D9"
                            TextColor="Black"
                            CornerRadius="20"
                            Margin="0,10,0,0"/>

                </VerticalStackLayout>
            </Frame>

            <Frame BackgroundColor="#F2F2F2"
                   CornerRadius="25"
                   Padding="20">

                <VerticalStackLayout Spacing="15">

                    <Grid ColumnDefinitions="*,Auto">
                        <Label Text="Riwayat Input Stock"
                               FontSize="18"
                               FontAttributes="Bold"/>
                        <Label Grid.Column="1" Text="📅"/>
                    </Grid>

                    <Frame CornerRadius="20"
                           BorderColor="#D6B3D9"
                           Padding="10">
                        <Grid ColumnDefinitions="Auto,*,Auto">

                            <Label Text="🧺" FontSize="28"/>

                            <VerticalStackLayout Grid.Column="1" Spacing="2">
                                <Label Text="Tepung Terigu" FontAttributes="Bold"/>
                                <Label Text="Karung, 25 maret 2027"
                                       FontSize="12"/>
                            </VerticalStackLayout>

                            <Label Grid.Column="2"
                                   Text="7:50 AM"
                                   VerticalOptions="Center"/>
                        </Grid>
                    </Frame>

                    <Frame CornerRadius="20"
                           BorderColor="#D6B3D9"
                           Padding="10">
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <Label Text="🥚" FontSize="28"/>

                            <VerticalStackLayout Grid.Column="1">
                                <Label Text="Telur" FontAttributes="Bold"/>
                                <Label Text="Papan, 25 maret 2027"
                                       FontSize="12"/>
                            </VerticalStackLayout>

                            <Label Grid.Column="2"
                                   Text="7:50 AM"
                                   VerticalOptions="Center"/>
                        </Grid>
                    </Frame>

                    <Frame CornerRadius="20"
                           BorderColor="#D6B3D9"
                           Padding="10">
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <Label Text="🧊" FontSize="28"/>

                            <VerticalStackLayout Grid.Column="1">
                                <Label Text="Gula" FontAttributes="Bold"/>
                                <Label Text="Kg, 25 maret 2027"
                                       FontSize="12"/>
                            </VerticalStackLayout>

                            <Label Grid.Column="2"
                                   Text="7:50 AM"
                                   VerticalOptions="Center"/>
                        </Grid>
                    </Frame>

                    <Frame CornerRadius="20"
                           BorderColor="#D6B3D9"
                           Padding="10">
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <Label Text="🧈" FontSize="28"/>

                            <VerticalStackLayout Grid.Column="1">
                                <Label Text="Mentega" FontAttributes="Bold"/>
                                <Label Text="Kg, 25 maret 2027"
                                       FontSize="12"/>
                            </VerticalStackLayout>

                            <Label Grid.Column="2"
                                   Text="7:50 AM"
                                   VerticalOptions="Center"/>
                        </Grid>
                    </Frame>

                    <Frame CornerRadius="20"
                           BorderColor="#D6B3D9"
                           Padding="10">
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <Label Text="🥛" FontSize="28"/>

                            <VerticalStackLayout Grid.Column="1">
                                <Label Text="Milk" FontAttributes="Bold"/>
                                <Label Text="Liter, 25 maret 2027"
                                       FontSize="12"/>
                            </VerticalOptions="Center"/>

                            <Label Grid.Column="2"
                                   Text="7:50 AM"
                                   VerticalOptions="Center"/>
                        </Grid>
                    </Frame>

                </VerticalStackLayout>
            </Frame>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>