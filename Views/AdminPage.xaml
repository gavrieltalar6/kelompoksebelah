<Window x:Class="App1.MainWindow"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Width="414" Height="896">

    <Window.Resources>
        <!-- Gaya dasar untuk Kartu Putih -->
        <Style TargetType="Border" x:Key="CardStyle">
            <Setter Property="Background" Value="White" />
            <Setter Property="CornerRadius" Value="15" />
            <Setter Property="Padding" Value="15" />
            <Setter Property="Margin" Value="0,0,0,15" />
        </Style>

        <!-- Gaya dasar untuk Teks -->
        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Jero" />
            <Setter Property="Foreground" Value="Black" />
        </Style>
    </Window.Resources>

    <!-- GRID UTAMA: Background Pink (#F1CBF1) dipasang di sini agar berfungsi di OpenSilver -->
    <Grid Background="#F1CBF1">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" /> <!-- Baris 0: Konten yang bisa di-scroll -->
            <RowDefinition Height="70" /> <!-- Baris 1: Area untuk Navigasi Bawah -->
        </Grid.RowDefinitions>

        <!-- ========================================== -->
        <!-- BAGIAN 1: KONTEN ATAS (SCROLLABLE)         -->
        <!-- ========================================== -->
        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="15,20,15,10">
                
                <!-- Judul -->
                <TextBlock Text="Bake Flow" FontSize="30" FontWeight="Bold" Margin="0,0,0,20" />

                <!-- Baris Metrik (3 Kotak Atas) -->
                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="White" Padding="10" CornerRadius="10" Margin="0,0,5,0">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Stok 6" FontSize="14" FontWeight="Bold" Margin="0,0,0,5" />
                            <TextBlock Text="85 Pcs" FontSize="14" FontWeight="Bold" />
                        </StackPanel>
                    </Border>
                    
                    <Border Grid.Column="1" Background="White" Padding="10" CornerRadius="10" Margin="5,0,5,0">
                        <TextBlock Text="Output Produksi" FontSize="14" FontWeight="Bold" VerticalAlignment="Center" />
                    </Border>
                    
                    <Border Grid.Column="2" Background="White" Padding="10" CornerRadius="10" Margin="5,0,0,0">
                        <TextBlock Text="Pesanan Terbanyak" FontSize="14" FontWeight="Bold" VerticalAlignment="Center" />
                    </Border>
                </Grid>

                <!-- Pemberitahuan & Alert -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Pemberitahuan &amp; Alert" FontSize="16" FontWeight="Bold" Margin="0,0,0,8" />
                        <TextBlock Text="Tepung Terigu : Kritis (25 Karung)" FontSize="14" FontWeight="Bold" Margin="0,0,0,8" />
                        <TextBlock Text="Aktivitas Baru : Transaksi Ricky #111070 (Tiramisu x1)" FontSize="14" FontWeight="Bold" />
                    </StackPanel>
                </Border>

                <!-- Laporan Penjualan -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <!-- Header Laporan -->
                        <Grid Margin="0,0,0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Laporan Penjualan (Terkini)" FontSize="16" FontWeight="Bold" VerticalAlignment="Center" />
                            
                            <!-- Tombol Lihat Semua -->
                            <Border Grid.Column="1" Background="#EBD5EB" Padding="10,5" CornerRadius="5">
                                <TextBlock Text="Lihat Semua" FontSize="11" FontWeight="Bold" VerticalAlignment="Center" />
                            </Border>
                        </Grid>
                        
                        <Rectangle Height="1" Fill="Black" Margin="0,0,0,10" />

                        <!-- List Penjualan -->
                        <StackPanel>
                            <Grid Margin="0,0,0,5"><Grid.ColumnDefinitions><ColumnDefinition Width="2*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="25 Mar, 17:50:00 AM" FontSize="12" FontWeight="Bold"/><TextBlock Grid.Column="1" Text="James" FontSize="12" FontWeight="Bold"/><TextBlock Grid.Column="2" Text="Rp 150.000" FontSize="12" FontWeight="Bold" HorizontalAlignment="Right"/>
                            </Grid>
                            <Grid Margin="0,0,0,5"><Grid.ColumnDefinitions><ColumnDefinition Width="2*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="25 Mar, 17:50:00 AM" FontSize="12" FontWeight="Bold"/><TextBlock Grid.Column="1" Text="Ricky" FontSize="12" FontWeight="Bold"/><TextBlock Grid.Column="2" Text="Rp 150.000" FontSize="12" FontWeight="Bold" HorizontalAlignment="Right"/>
                            </Grid>
                            <Grid Margin="0,0,0,5"><Grid.ColumnDefinitions><ColumnDefinition Width="2*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="25 Mar, 17:50:00 AM" FontSize="12" FontWeight="Bold"/><TextBlock Grid.Column="1" Text="Agus" FontSize="12" FontWeight="Bold"/><TextBlock Grid.Column="2" Text="Rp 150.000" FontSize="12" FontWeight="Bold" HorizontalAlignment="Right"/>
                            </Grid>
                            <Grid Margin="0,0,0,5"><Grid.ColumnDefinitions><ColumnDefinition Width="2*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="25 Mar, 17:50:00 AM" FontSize="12" FontWeight="Bold"/><TextBlock Grid.Column="1" Text="Agus" FontSize="12" FontWeight="Bold"/><TextBlock Grid.Column="2" Text="Rp 150.000" FontSize="12" FontWeight="Bold" HorizontalAlignment="Right"/>
                            </Grid>
                            <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="2*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="25 Mar, 17:50:00 AM" FontSize="12" FontWeight="Bold"/><TextBlock Grid.Column="1" Text="Agus" FontSize="12" FontWeight="Bold"/><TextBlock Grid.Column="2" Text="Rp 150.000" FontSize="12" FontWeight="Bold" HorizontalAlignment="Right"/>
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Katalog Produk -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <!-- Header Katalog -->
                        <Grid Margin="0,0,0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Katalog Produk" FontSize="20" FontWeight="Bold" />
                            <TextBlock Grid.Column="1" Text="▲" Foreground="#DABEE0" FontSize="18" VerticalAlignment="Center" />
                        </Grid>
                        
                        <TextBlock Text="Product" FontSize="12" FontWeight="Bold" Margin="0,0,0,5" />
                        <Rectangle Height="1" Fill="Black" Margin="0,0,0,15" />

                        <!-- Produk 1 -->
                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="60" Height="60" CornerRadius="10" Margin="0,0,15,0" Background="#DDDDDD">
                                <!-- Hapus baris Background="#DDDDDD" di atas jika gambar tiramisu.png sudah ada -->
                                <Border.Background>
                                    <ImageBrush ImageSource="tiramisu.png" Stretch="UniformToFill" />
                                </Border.Background>
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="Kue Tiramisu" FontSize="12" FontWeight="Bold" Margin="0,0,0,4" />
                                <TextBlock Text="Rp 20k" FontSize="12" FontWeight="Bold" />
                            </StackPanel>
                            <TextBlock Grid.Column="2" Text="Rp 550.000" FontSize="14" FontWeight="Bold" VerticalAlignment="Center" />
                        </Grid>

                        <!-- Produk 2 -->
                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="60" Height="60" CornerRadius="10" Margin="0,0,15,0" Background="#DDDDDD">
                                <Border.Background>
                                    <ImageBrush ImageSource="balok.png" Stretch="UniformToFill" />
                                </Border.Background>
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="Kue Balok Cokelat" FontSize="12" FontWeight="Bold" Margin="0,0,0,4" />
                                <TextBlock Text="Rp 50k" FontSize="12" FontWeight="Bold" />
                            </StackPanel>
                            <TextBlock Grid.Column="2" Text="Rp 550.000" FontSize="14" FontWeight="Bold" VerticalAlignment="Center" />
                        </Grid>

                        <!-- Produk 3 -->
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="60" Height="60" CornerRadius="10" Margin="0,0,15,0" Background="#DDDDDD">
                                <Border.Background>
                                    <ImageBrush ImageSource="roblox.png" Stretch="UniformToFill" />
                                </Border.Background>
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="Kue Roblox" FontSize="12" FontWeight="Bold" Margin="0,0,0,4" />
                                <TextBlock Text="Rp 170k" FontSize="12" FontWeight="Bold" />
                            </StackPanel>
                            <TextBlock Grid.Column="2" Text="Rp 550.000" FontSize="14" FontWeight="Bold" VerticalAlignment="Center" />
                        </Grid>

                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- ========================================== -->
        <!-- BAGIAN 2: BOTTOM NAVIGATION                -->
        <!-- ========================================== -->
        
        <!-- CornerRadius dibuat 20,20,20,20 agar semua ujung (termasuk bawah) melengkung seperti di foto Anda -->
        <Border Grid.Row="1" Background="White" CornerRadius="20" Padding="0,5" Margin="5,0,5,5">
            <Grid VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                    <Image Source="https://img.icons8.com/ios-filled/50/000000/home.png" Height="24" Width="24" Margin="0,0,0,2" />
                    <TextBlock Text="Home" FontSize="10" HorizontalAlignment="Center" />
                </StackPanel>

                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                    <Image Source="https://img.icons8.com/ios-filled/50/000000/warehouse.png" Height="24" Width="24" Margin="0,0,0,2" />
                    <TextBlock Text="Warehouse" FontSize="10" HorizontalAlignment="Center" />
                </StackPanel>

                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                    <Image Source="https://img.icons8.com/ios-filled/50/000000/cash-register.png" Height="24" Width="24" Margin="0,0,0,2" />
                    <TextBlock Text="Cashier" FontSize="10" HorizontalAlignment="Center" />
                </StackPanel>

                <StackPanel Grid.Column="3" HorizontalAlignment="Center">
                    <Image Source="https://img.icons8.com/ios-filled/50/000000/chef-hat--v1.png" Height="24" Width="24" Margin="0,0,0,2" />
                    <TextBlock Text="Kitchen" FontSize="10" HorizontalAlignment="Center" />
                </StackPanel>

                <StackPanel Grid.Column="4" HorizontalAlignment="Center">
                    <Image Source="https://img.icons8.com/ios-filled/50/000000/restaurant-menu.png" Height="24" Width="24" Margin="0,0,0,2" />
                    <TextBlock Text="Menu" FontSize="10" HorizontalAlignment="Center" />
                </StackPanel>

                <StackPanel Grid.Column="5" HorizontalAlignment="Center">
                    <Image Source="https://img.icons8.com/ios-filled/50/000000/settings.png" Height="24" Width="24" Margin="0,0,0,2" />
                    <TextBlock Text="Setting" FontSize="10" HorizontalAlignment="Center" />
                </StackPanel>
            </Grid>
        </Border>

    </Grid>
</Window>