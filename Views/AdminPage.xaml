<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:CakeProject"
             x:Class="CakeProject.Views.AdminPage"
             BackgroundColor="#F1CBF1">

    <ContentPage.Resources>
        <Style TargetType="Border"
               x:Key="CardStyle">
            <Setter Property="BackgroundColor"
                    Value="White"/>
            <Setter Property="Padding"
                    Value="15"/>
            <Setter Property="Margin"
                    Value="0,0,0,15"/>
            <Setter Property="StrokeShape">
                <Setter.Value>
                    <RoundRectangle CornerRadius="15"/>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="Label">
            <Setter Property="TextColor"
                    Value="Black"/>
        </Style>
    </ContentPage.Resources>

    <Grid RowDefinitions="*,70">

        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="15,20,15,10"
                                 Spacing="15">

                <Label Text="Bake Flow"
                       FontSize="30"
                       FontAttributes="Bold"/>

                <!-- METRICS -->
                <Grid ColumnDefinitions="*,*,*"
                      ColumnSpacing="10">
                    <Border Grid.Column="0"
                            Padding="10">
                        <VerticalStackLayout>
                            <Label Text="Stok Kritis"
                                   FontAttributes="Bold"
                                   FontSize="11"/>
                            <Label Text="{Binding JumlahStokKritis, StringFormat='{0} Bahan'}"
                                   FontAttributes="Bold"
                                   FontSize="18"/>
                        </VerticalStackLayout>
                    </Border>
                    <Border Grid.Column="1"
                            Padding="10">
                        <VerticalStackLayout>
                            <Label Text="Total Produk"
                                   FontAttributes="Bold"
                                   FontSize="11"/>
                            <Label Text="{Binding JumlahProduk, StringFormat='{0} Jenis'}"
                                   FontAttributes="Bold"
                                   FontSize="18"/>
                        </VerticalStackLayout>
                    </Border>
                    <Border Grid.Column="2"
                            Padding="10">
                        <VerticalStackLayout>
                            <Label Text="Terlaris"
                                   FontAttributes="Bold"
                                   FontSize="11"/>
                            <Label Text="{Binding ProdukTerlaris}"
                                   FontAttributes="Bold"
                                   FontSize="13"/>
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <!-- ALERT -->
                <Border Style="{StaticResource CardStyle}">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Pemberitahuan &amp; Alert"
                               FontAttributes="Bold"
                               TextColor="Black"/>
                        <VerticalStackLayout x:Name="AlertContainer"
                                             Spacing="5"/>
                    </VerticalStackLayout>
                </Border>

                <!-- LAPORAN PENJUALAN -->
                <Border Style="{StaticResource CardStyle}">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Laporan Penjualan (Terkini)"
                               FontAttributes="Bold"
                               TextColor="Black"/>
                        <BoxView HeightRequest="1"
                                 Color="Black"/>
                        <VerticalStackLayout x:Name="LaporanContainer"
                                             Spacing="2"/>
                    </VerticalStackLayout>
                </Border>

                <!-- KATALOG PRODUK + EDIT HARGA -->
                <Border Style="{StaticResource CardStyle}">
                    <VerticalStackLayout Spacing="15">
                        <Label Text="Katalog Produk"
                               FontSize="20"
                               FontAttributes="Bold"
                               TextColor="Black"/>
                        <BoxView HeightRequest="1"
                                Color="Black"/>
                        <VerticalStackLayout x:Name="ProdukContainer"
                                Spacing="2"/>
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

        <!-- BOTTOM NAV (belum fungsional) -->
        <Border Grid.Row="1"
                BackgroundColor="White"
                Margin="5"
                Padding="5">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="20"/>
            </Border.StrokeShape>
            <Grid ColumnDefinitions="*,*,*,*,*,*">
                <VerticalStackLayout HorizontalOptions="Center">
                    <Image Source="home.png"
                           HeightRequest="24"/>
                    <Label Text="Home"
                           FontSize="10"/>
                </VerticalStackLayout>
                <VerticalStackLayout Grid.Column="1"
                                     HorizontalOptions="Center">
                    <Image Source="warehouse.png"
                           HeightRequest="24"/>
                    <Label Text="Warehouse"
                           FontSize="10"/>
                </VerticalStackLayout>
                <VerticalStackLayout Grid.Column="2"
                                     HorizontalOptions="Center">
                    <Image Source="cashier.png"
                           HeightRequest="24"/>
                    <Label Text="Cashier"
                           FontSize="10"/>
                </VerticalStackLayout>
                <VerticalStackLayout Grid.Column="3"
                                     HorizontalOptions="Center">
                    <Image Source="kitchen.png"
                           HeightRequest="24"/>
                    <Label Text="Kitchen"
                           FontSize="10"/>
                </VerticalStackLayout>
                <VerticalStackLayout Grid.Column="4"
                                     HorizontalOptions="Center">
                    <Image Source="menu.png"
                           HeightRequest="24"/>
                    <Label Text="Menu"
                           FontSize="10"/>
                </VerticalStackLayout>
                <VerticalStackLayout Grid.Column="5"
                                     HorizontalOptions="Center">
                    <Image Source="settings.png"
                           HeightRequest="24"/>
                    <Label Text="Setting"
                           FontSize="10"/>
                </VerticalStackLayout>
            </Grid>
        </Border>

    </Grid>
</ContentPage>