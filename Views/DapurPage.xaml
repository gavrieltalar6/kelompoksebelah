<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="YourApp.AmbilStockPage"
             BackgroundColor="#D6B3D9">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">

            <Grid ColumnDefinitions="Auto,*,Auto">
                <Label Text="←" FontSize="20" VerticalOptions="Center"/>
                <Label Grid.Column="1"
                       Text=""
                       FontSize="24"
                       HorizontalOptions="Center"/>
                <Label Grid.Column="2"
                       Text="?"
                       FontSize="20"
                       VerticalOptions="Center"/>
            </Grid>

            <Frame BackgroundColor="#F2F2F2"
                   CornerRadius="25"
                   Padding="20">

                <VerticalStackLayout Spacing="15">

                    <Label Text="Ambil Bahan dari Gudang"
                           FontAttributes="Bold"
                           FontSize="18"/>

                    <Label Text="Pilih Bahan"/>
                    <Frame CornerRadius="15" Padding="0" BorderColor="#D6B3D9">
                        <Picker Title=""/>
                    </Frame>

                    <Label Text="Jumlah Bahan Diambil"/>
                    <Frame CornerRadius="15" Padding="0" BorderColor="#D6B3D9">
                        <Entry Keyboard="Numeric"/>
                    </Frame>

                    <Label Text="Tanggal Pengambilan"/>
                    <Frame CornerRadius="15" Padding="5" BorderColor="#D6B3D9">
                        <DatePicker/>
                    </Frame>

                    <Button Text="Ambil Stock"
                            BackgroundColor="#D6B3D9"
                            CornerRadius="20"/>
                </VerticalStackLayout>
            </Frame>

            <Frame BackgroundColor="#F2F2F2"
                   CornerRadius="25"
                   Padding="20">

                <VerticalStackLayout Spacing="12">

                    <Label Text="Status Stock Saat ini"
                           FontAttributes="Bold"
                           FontSize="18"/>

                    <Frame CornerRadius="20" BackgroundColor="#8FE388">
                        <Grid ColumnDefinitions="Auto,*,Auto" Padding="10">
                            <Label Text="✔"/>
                            <Label Grid.Column="1" Text="Tepung Terigu"/>
                            <Label Grid.Column="2" Text="25 Karung"/>
                        </Grid>
                    </Frame>

                    <Frame CornerRadius="20" BackgroundColor="#8FE388">
                        <Grid ColumnDefinitions="Auto,*,Auto" Padding="10">
                            <Label Text="✔"/>
                            <Label Grid.Column="1" Text="Telur"/>
                            <Label Grid.Column="2" Text="10 Papan"/>
                        </Grid>
                    </Frame>

                    <Frame CornerRadius="20" BackgroundColor="#8FE388">
                        <Grid ColumnDefinitions="Auto,*,Auto" Padding="10">
                            <Label Text="✔"/>
                            <Label Grid.Column="1" Text="Gula"/>
                            <Label Grid.Column="2" Text="5 Kg"/>
                        </Grid>
                    </Frame>

                    <Frame CornerRadius="20" BackgroundColor="#F3D37A">
                        <Grid ColumnDefinitions="Auto,*,Auto" Padding="10">
                            <Label Text="⚠"/>
                            <Label Grid.Column="1" Text="Mentega"/>
                            <Label Grid.Column="2" Text="4 Kg"/>
                        </Grid>
                    </Frame>

                    <Frame CornerRadius="20" BackgroundColor="#F26C6C">
                        <Grid ColumnDefinitions="Auto,*,Auto" Padding="10">
                            <Label Text="⛔"/>
                            <Label Grid.Column="1" Text="Susu"/>
                            <Label Grid.Column="2" Text="1 Liter"/>
                        </Grid>
                    </Frame>

                </VerticalStackLayout>
            </Frame>

            <Frame BackgroundColor="#F2F2F2"
                   CornerRadius="25"
                   Padding="20">

                <VerticalStackLayout Spacing="15">

                    <Label Text="Catat Hasil Produksi"
                           FontAttributes="Bold"
                           FontSize="18"/>

                    <Label Text="Pilih Kue"/>
                    <Grid ColumnDefinitions="*,*"
                          BackgroundColor="#E3C6E8"
                          Padding="5">

                        <Button Text="Red Velvet Cake"
                                BackgroundColor="#BFBFBF"
                                CornerRadius="15"/>
                        <Button Text="Chocolate Lava"
                                Grid.Column="1"
                                BackgroundColor="Transparent"/>
                    </Grid>

                    <Label Text="Jumlah Hasil"/>
                    <Frame CornerRadius="15" Padding="0" BorderColor="#D6B3D9">
                        <Entry Keyboard="Numeric"/>
                    </Frame>

                    <Label Text="Satuan"/>
                    <Grid ColumnDefinitions="*,*"
                          BackgroundColor="#E3C6E8"
                          Padding="5">

                        <Button Text="Pcs"
                                BackgroundColor="#BFBFBF"
                                CornerRadius="15"/>
                        <Button Text="Loyang"
                                Grid.Column="1"
                                BackgroundColor="Transparent"/>
                    </Grid>

                    <Label Text="Tanggal Produksi"/>
                    <Frame CornerRadius="15" Padding="5" BorderColor="#D6B3D9">
                        <DatePicker/>
                    </Frame>

                    <Button Text="Ambil Stock"
                            BackgroundColor="#D6B3D9"
                            CornerRadius="20"/>

                </VerticalStackLayout>
            </Frame>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>