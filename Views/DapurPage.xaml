<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:CakeProject.ViewModels"
             xmlns:cvt="clr-namespace:CakeProject.Converters"
             x:Class="CakeProject.Views.DapurPage"
             BackgroundColor="#D6B3D9">

    <ContentPage.Resources>
        <ResourceDictionary>
            <cvt:SatuanColorConverter x:Key="SatuanColorConverter"/>
            <cvt:BoolToColorConverter x:Key="BoolToColorConverter"/>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="*,70">

        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="20" Spacing="20">

                <Grid ColumnDefinitions="Auto,*,Auto">
                    <Label Text="←" FontSize="20" VerticalOptions="Center"/>
                    <Label Grid.Column="1"
                           Text="Manajemen Dapur"
                           FontSize="24"
                           FontAttributes="Bold"
                           HorizontalOptions="Center"/>
                    <Label Grid.Column="2" Text="?" FontSize="20" VerticalOptions="Center"/>
                </Grid>

                <Frame BackgroundColor="#F2F2F2" CornerRadius="25" Padding="20">
                    <VerticalStackLayout Spacing="15">
                        <Label Text="Ambil Bahan dari Gudang" FontAttributes="Bold" FontSize="18"/>
                        <Label Text="Pilih Bahan Baku"/>
                        <Frame CornerRadius="15" Padding="0" BorderColor="#D6B3D9">
                            <Picker Title="Pilih bahan..."
                                    ItemsSource="{Binding ListBahanGudang}"
                                    ItemDisplayBinding="{Binding NamaBarang}"
                                    SelectedItem="{Binding BahanTerpilih}"/>
                        </Frame>
                        <Label Text="Jumlah Bahan Diambil"/>
                        <Frame CornerRadius="15" Padding="0" BorderColor="#D6B3D9">
                            <Entry Keyboard="Numeric"
                                   Text="{Binding JumlahAmbil}"
                                   Placeholder="Contoh: 5"/>
                        </Frame>
                        <Button Text="Proses Pengambilan"
                                Command="{Binding AmbilBahanCommand}"
                                BackgroundColor="#D6B3D9"
                                TextColor="Black"
                                CornerRadius="20"/>
                    </VerticalStackLayout>
                </Frame>

                <Frame BackgroundColor="#F2F2F2" CornerRadius="25" Padding="20">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="Status Stok Baku Saat Ini" FontAttributes="Bold" FontSize="18"/>
                        <CollectionView ItemsSource="{Binding ListBahanGudang}">
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Frame CornerRadius="20" BackgroundColor="#8FE388" Margin="0,5" Padding="5">
                                        <Grid ColumnDefinitions="Auto,*,Auto" Padding="10">
                                            <Label Text="✔" VerticalOptions="Center"/>
                                            <Label Grid.Column="1"
                                                   Text="{Binding NamaBarang}"
                                                   Margin="10,0"
                                                   VerticalOptions="Center"
                                                   FontAttributes="Bold"/>
                                            <StackLayout Grid.Column="2" Orientation="Horizontal" VerticalOptions="Center">
                                                <Label Text="{Binding JumlahStok}"/>
                                                <Label Text="{Binding Satuan}" Margin="5,0,0,0"/>
                                            </StackLayout>
                                        </Grid>
                                    </Frame>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </Frame>

                <Frame BackgroundColor="#F2F2F2" CornerRadius="25" Padding="20">
                    <VerticalStackLayout Spacing="15">
                        <Label Text="Catat Hasil Produksi" FontAttributes="Bold" FontSize="18"/>
                        <Label Text="Pilih Produk Hasil"/>

                        <CollectionView ItemsSource="{Binding ListKueTersedia}" HeightRequest="55">
                            <CollectionView.ItemsLayout>
                                <LinearItemsLayout Orientation="Horizontal" ItemSpacing="10"/>
                            </CollectionView.ItemsLayout>
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Button Text="{Binding NamaBarang}"
                                            FontSize="12"
                                            CornerRadius="15"
                                            TextColor="Black"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.PilihKueCommand}"
                                            CommandParameter="{Binding .}"
                                            BackgroundColor="{Binding IsAktif, Converter={StaticResource BoolToColorConverter}}"/>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>

                        <Label Text="Jumlah Hasil Produksi (per satuan dijual)"/>
                        <Frame CornerRadius="15" Padding="0" BorderColor="#D6B3D9">
                            <Entry Keyboard="Numeric" Text="{Binding JumlahProduksi}"/>
                        </Frame>

                        <Button Text="Simpan Hasil Ke Stok"
                                Command="{Binding SimpanProduksiCommand}"
                                BackgroundColor="#D6B3D9"
                                TextColor="Black"
                                FontAttributes="Bold"
                                CornerRadius="20"/>
                    </VerticalStackLayout>
                </Frame>

            </VerticalStackLayout>
        </ScrollView>

        <!-- BOTTOM NAV -->
        <Border Grid.Row="1" BackgroundColor="White" Margin="5" Padding="5">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="20"/>
            </Border.StrokeShape>
            <Grid ColumnDefinitions="*,*,*,*,*,*">

                <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="2">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnAdminClicked"/>
                    </VerticalStackLayout.GestureRecognizers>
                    <Border BackgroundColor="Transparent" Padding="8,5" HorizontalOptions="Center">
                        <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                        <Label Text="🏠" FontSize="20" HorizontalOptions="Center"/>
                    </Border>
                    <Label Text="Admin" FontSize="10" TextColor="#888888" HorizontalOptions="Center"/>
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center" VerticalOptions="Center" Spacing="2">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnGudangClicked"/>
                    </VerticalStackLayout.GestureRecognizers>
                    <Border BackgroundColor="Transparent" Padding="8,5" HorizontalOptions="Center">
                        <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                        <Label Text="🏭" FontSize="20" HorizontalOptions="Center"/>
                    </Border>
                    <Label Text="Gudang" FontSize="10" TextColor="#888888" HorizontalOptions="Center"/>
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Column="2" HorizontalOptions="Center" VerticalOptions="Center" Spacing="2">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnDapurClicked"/>
                    </VerticalStackLayout.GestureRecognizers>
                    <Border BackgroundColor="#EBD5EB" Padding="8,5" HorizontalOptions="Center">
                        <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                        <Label Text="🍳" FontSize="20" HorizontalOptions="Center"/>
                    </Border>
                    <Label Text="Dapur" FontSize="10" FontAttributes="Bold" TextColor="#7B3F7B" HorizontalOptions="Center"/>
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Column="3" HorizontalOptions="Center" VerticalOptions="Center" Spacing="2">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnResepClicked"/>
                    </VerticalStackLayout.GestureRecognizers>
                    <Border BackgroundColor="Transparent" Padding="8,5" HorizontalOptions="Center">
                        <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                        <Label Text="📖" FontSize="20" HorizontalOptions="Center"/>
                    </Border>
                    <Label Text="Resep" FontSize="10" TextColor="#888888" HorizontalOptions="Center"/>
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Column="4" HorizontalOptions="Center" VerticalOptions="Center" Spacing="2">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnKasirClicked"/>
                    </VerticalStackLayout.GestureRecognizers>
                    <Border BackgroundColor="Transparent" Padding="8,5" HorizontalOptions="Center">
                        <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                        <Label Text="🧾" FontSize="20" HorizontalOptions="Center"/>
                    </Border>
                    <Label Text="POS" FontSize="10" TextColor="#888888" HorizontalOptions="Center"/>
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Column="5" HorizontalOptions="Center" VerticalOptions="Center" Spacing="2">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnMemberClicked"/>
                    </VerticalStackLayout.GestureRecognizers>
                    <Border BackgroundColor="Transparent" Padding="8,5" HorizontalOptions="Center">
                        <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                        <Label Text="👥" FontSize="20" HorizontalOptions="Center"/>
                    </Border>
                    <Label Text="Member" FontSize="10" TextColor="#888888" HorizontalOptions="Center"/>
                </VerticalStackLayout>

            </Grid>
        </Border>

    </Grid>
</ContentPage>
